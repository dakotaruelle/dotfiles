# Config syntax crash course

# ==========================

# # The config file consists of simple key-value pairs,

# # separated by equals signs.

# font-family = Iosevka

# window-padding-x = 2

#

# # Spacing around the equals sign does not matter.

# # All of these are identical:

# key=value

# key= value

# key =value

# key = value

#

# # Any line beginning with a # is a comment. It's not possible to put

# # a comment after a config option, since it would be interpreted as a

# # part of the value. For example, this will have a value of "#123abc":

# background = #123abc

#

# # Empty values are used to reset config keys to default.

# key =

#

# # Some config options have unique syntaxes for their value,

# # which is explained in the docs for that config option.

# # Just for example:

# resize-overlay-duration = 4s 200ms

theme = Ayu
window-titlebar-background = #11151C
window-titlebar-foreground = #11151C
gtk-titlebar-style = tabs
gtk-wide-tabs = false
faint-opacity = 0.7
background-image = /home/dakota/Pictures/Wallpapers/slate.jpg
background-image-fit = cover
font-family = "JetBrainsMono NF"

# Reload configuration

keybind = ctrl+shift+,=reload_config

# Create new split down

keybind = ctrl+shift+arrow_down=new_split:down

# Go to previous split

keybind = ctrl+shift+page_up=goto_split:previous

# Go to next split

keybind = ctrl+shift+page_down=goto_split:next

# New tab

keybind = ctrl+t=new_tab

# Close tab

keybind = ctrl+w=close_tab

# Close split

keybind = ctrl+shift+w=close_surface

# Paste

keybind = ctrl+v=paste_from_clipboard
